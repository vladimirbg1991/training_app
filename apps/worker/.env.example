# Supabase (service role -- SECRET, never expose to client)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Postgres (direct connection, NOT Supavisor -- per CLAUDE.md)
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# Redis (for BullMQ -- use Redis Cloud or Upstash Fixed, NOT PAYG)
REDIS_URL=redis://default:password@your-redis-host:6379

# Clerk (secret key for server-side verification)
CLERK_SECRET_KEY=sk_test_your-clerk-secret-key

# Mux (secret)
MUX_TOKEN_ID=your-mux-token-id
MUX_TOKEN_SECRET=your-mux-token-secret

# ExerciseDB (secret)
EXERCISEDB_API_KEY=your-exercisedb-api-key

# Sentry
SENTRY_DSN=https://your-key@sentry.io/your-worker-project-id
