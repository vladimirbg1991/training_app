# Supabase (public -- safe for client)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# PowerSync
EXPO_PUBLIC_POWERSYNC_URL=https://your-instance.powersync.journeyapps.com

# Clerk (publishable key -- safe for client)
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your-clerk-key

# PostHog (public project key -- safe for client)
EXPO_PUBLIC_POSTHOG_KEY=phc_your-posthog-key
EXPO_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# RevenueCat (public SDK key -- safe for client)
EXPO_PUBLIC_REVENUECAT_APPLE_KEY=appl_your-revenuecat-key
EXPO_PUBLIC_REVENUECAT_GOOGLE_KEY=goog_your-revenuecat-key

# Sentry (DSN is public by design)
EXPO_PUBLIC_SENTRY_DSN=https://your-key@sentry.io/your-project-id
