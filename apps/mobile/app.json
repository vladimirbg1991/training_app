{
  "expo": {
    "name": "Pulse",
    "slug": "pulse",
    "version": "0.1.0",
    "scheme": "gymapp",
    "sdkVersion": "55.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "platforms": ["ios", "android"],
    "icon": "./assets/icon.png",
    "ios": {
      "bundleIdentifier": "com.pulse.fitness",
      "supportsTablet": false,
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Pulse uses the camera to scan gym equipment QR codes.",
        "NSHealthShareUsageDescription": "Pulse reads your workouts from Apple Health to show a complete training history.",
        "NSHealthUpdateUsageDescription": "Pulse writes completed workouts to Apple Health."
      }
    },
    "android": {
      "package": "com.pulse.fitness",
      "adaptiveIcon": {
        "backgroundColor": "#0A1410"
      }
    },
    "plugins": [
      "expo-router",
      "@sentry/react-native",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0A1410"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
